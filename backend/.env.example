# Backend env vars (all optional; defaults shown).
# Copy to .env and adjust as needed. Loaded by pydantic-settings.

POS_INVENTORY_DB_DSN=postgresql+psycopg://postgres:postgres@localhost:5432/pos_inventory

# Dev mode: when true, the API accepts X-Dev-Tenant / X-Dev-User / X-Dev-Roles
# request headers in lieu of a signed JWT. NEVER enable in production.
POS_INVENTORY_AUTH_BYPASS=true

# Required only when AUTH_BYPASS=false.
# POS_INVENTORY_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----...
# POS_INVENTORY_JWT_AUDIENCE=pos-inventory

# Optional: outbox worker webhook target.
# POS_INVENTORY_OUTBOX_WEBHOOK_URL=https://example.com/hooks/inventory

# Default over-receive tolerance (%) when no per-tenant config row exists.
POS_INVENTORY_OVER_RECEIVE_TOLERANCE_PCT_DEFAULT=10

# Explicit opt-in required by `python -m pos_inventory.scripts.seed_dev` when
# AUTH_BYPASS is false (e.g. running the seed as a one-off task in cloud).
# POS_INVENTORY_ALLOW_SEED=true
